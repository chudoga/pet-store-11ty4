---
pagination:
  data: products
  size: 1
  alias: product
permalink: /products/{{ product.id }}.html
title: "{{ product.name_zh }}"
description: "{{ product.description_zh }}"
layout: layouts/layout.njk
---
<section class="py-12 px-4">
  <div class="max-w-6xl mx-auto">
    <a href="{{ '/products' | url }}" class="inline-flex items-center text-primary hover:text-primary/80 mb-6 font-medium">← 返回商品目录</a>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
      <div class="aspect-square bg-gray-200 rounded-xl flex items-center justify-center"><span class="text-gray-400">商品图片</span></div>
      <div>
        <div class="inline-block px-3 py-1 rounded-full text-sm font-medium bg-secondary/20 text-secondary mb-3">{{ categoryMap[product.category] }}</div>
        <h1 class="text-3xl md:text-4xl font-bold text-text mb-4">{{ product.name_zh }}</h1>
        <p class="text-4xl font-bold text-accent mb-6">¥{{ product.price }}</p>
        <p class="text-text/80 leading-relaxed text-lg">{{ product.description_zh }}</p>
      </div>
    </div>
    {% if related.length > 0 %}
    <div>
      <h2 class="text-2xl font-bold text-text mb-6">相关商品</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {% for rel in related %}
        <a href="{{ pathPrefix }}/products/{{ rel.id }}" class="group">
          <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300">
            <div class="aspect-square bg-gray-200 flex items-center justify-center"><span class="text-gray-400 text-sm">商品图片</span></div>
            <div class="p-4"><h3 class="font-semibold text-lg mb-2 text-text group-hover:text-primary transition-colors">{{ rel.name_zh }}</h3><p class="text-2xl font-bold text-accent">¥{{ rel.price }}</p></div>
          </div>
        </a>
        {% endfor %}
      </div>
    </div>
    {% endif %}
  </div>
</section>
